generator client {
  provider = "prisma-client"
  output   = "./generated/"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String? // опционально дляя oauth юзеров
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image String?  // дляя oauth юзеров
  emailVerified DateTime? // oauth

   // связи с OAuth
  accounts      Account[]
  sessions      Session[]

  //мои модели
  settings  UserSettings?
  progress  UserProgress?
  economy   UserEconomy?
}
//нужно для регистрации
model TemporaryUser {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String?
  verificationCode String // тк может содержать ведущие нули
  codeExpiresAt    DateTime
  createdAt        DateTime @default(now())

  @@index([email])
  @@index([verificationCode])
}

// МОДЕЛИ ДЛЯ OAuth (ОБЯЗАТЕЛЬНЫЕ)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}


//мои модели
model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme     String   @default("light")
  font      String   @default("sans")
  logo      String   @default("🐙")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  themesOfWords           Json @default("[]")
  countOfLearnedWords     Int      @default(0)
  countOfThemesNeedToRepeat Int    @default(0)
  lastVisit               DateTime @default(now())
  streak                  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserEconomy {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  money     Int      @default(0)
  rubies    Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
